{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/indonesian-map-tools/license-manifest-schema-v1.json",
  "title": "Indonesian Map Tools License Manifest v1",
  "type": "object",
  "required": ["schemaVersion", "manifestVersion", "projectLicense", "policy", "assets"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "manifestVersion": { "type": "string", "minLength": 1 },
    "projectLicense": {
      "type": "object",
      "required": ["codeLicenseId", "notice"],
      "additionalProperties": false,
      "properties": {
        "codeLicenseId": { "type": "string", "minLength": 1 },
        "notice": { "type": "string", "minLength": 1 }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "productionAssetsFailClosed",
        "commercialUseRequiresExplicitStatus",
        "redistributionRequiresExplicitStatus",
        "checksumRequiredForLocalFiles",
        "attributionRequiredWhenLicenseRequiresIt",
        "sourceVersionChangeRequiresReview"
      ],
      "additionalProperties": false,
      "properties": {
        "productionAssetsFailClosed": { "type": "boolean" },
        "commercialUseRequiresExplicitStatus": { "type": "boolean" },
        "redistributionRequiresExplicitStatus": { "type": "boolean" },
        "checksumRequiredForLocalFiles": { "type": "boolean" },
        "attributionRequiredWhenLicenseRequiresIt": { "type": "boolean" },
        "sourceVersionChangeRequiresReview": { "type": "boolean" }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "title",
          "publisherOwner",
          "exactSource",
          "licenseId",
          "commercialUseStatus",
          "modificationStatus",
          "redistributionStatus",
          "attributionRequired",
          "attributionText",
          "review",
          "productionApproved"
        ],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string" },
          "packageName": { "type": "string" },
          "lockfilePackage": { "type": "string" },
          "publisherOwner": { "type": "string", "minLength": 1 },
          "exactSource": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string" },
          "mediaType": { "type": "string" },
          "licenseId": { "type": "string", "minLength": 1 },
          "commercialUseStatus": { "type": "string", "minLength": 1 },
          "modificationStatus": { "type": "string", "minLength": 1 },
          "redistributionStatus": { "type": "string", "minLength": 1 },
          "attributionRequired": { "type": "boolean" },
          "attributionText": { "type": "string" },
          "review": {
            "type": "object",
            "required": ["status", "reviewer", "date"],
            "additionalProperties": false,
            "properties": {
              "status": { "type": "string", "minLength": 1 },
              "reviewer": { "type": "string", "minLength": 1 },
              "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            }
          },
          "productionApproved": { "type": "boolean" }
        }
      }
    }
  }
}
